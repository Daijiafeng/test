# TestMind 环境配置示例

# ============================================
# 服务配置
# ============================================
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
ENVIRONMENT=development

# ============================================
# 数据库配置
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=testmind
DB_PASSWORD=testmind123
DB_NAME=testmind
DB_SSL_MODE=disable

# ============================================
# JWT配置
# ============================================
# 生产环境必须使用32位以上的随机字符串
JWT_SECRET=testmind-secret-key-min-32-characters-required-for-production
JWT_ACCESS_TOKEN_EXP=2
JWT_REFRESH_TOKEN_EXP=7

# ============================================
# 飞书配置
# ============================================
# 从飞书开放平台获取：https://open.feishu.cn/app
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OAuth回调地址，需要配置为你的域名
FEISHU_REDIRECT_URI=https://your-domain.com/api/v1/feishu/oauth/callback

# ============================================
# AI配置
# ============================================
# 运行模式：cloud（云端API）| local（本地模型）| hybrid（混合）
AI_MODE=cloud

# 云端AI服务（OpenAI）
AI_CLOUD_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AI_CLOUD_MODEL=gpt-4

# 本地模型配置（可选）
AI_LOCAL_MODEL_PATH=/models
AI_LOCAL_MODEL_PORT=8000

# ============================================
# Redis配置（可选）
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================
# CORS配置
# ============================================
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS