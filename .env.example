# TestMind 环境配置示例
# 复制为 .env 并填入实际值

# 服务配置
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
ENVIRONMENT=development

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=testmind
DB_PASSWORD=your_password_here
DB_NAME=testmind
DB_SSL_MODE=disable

# JWT配置
JWT_SECRET=your_jwt_secret_key_here_min_32_characters
JWT_ACCESS_TOKEN_EXP=2
JWT_REFRESH_TOKEN_EXP=7

# 飞书应用配置
FEISHU_APP_ID=cli_xxxxx
FEISHU_APP_SECRET=your_app_secret_here
FEISHU_REDIRECT_URI=http://localhost:8080/api/v1/auth/feishu/callback

# AI服务配置
AI_MODE=cloud
AI_CLOUD_API_KEY=sk-xxxxx
AI_CLOUD_MODEL=gpt-4
# AI_LOCAL_MODEL_PATH=/opt/models
# AI_LOCAL_MODEL_PORT=8000